<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>aps-environment</key>
	<string>production</string>
	<!-- Tap to Pay on iPhone — GRANTED by Apple (Case-ID 20814883, dev-distribution tier)
	     and, as of 2026-07-02, PROPAGATED to the com.gotvero.app App ID: added back in Xcode
	     via Signing & Capabilities → + Capability → "Tap to Pay on iPhone" (which registered
	     it with the App ID + regenerated the profile). Build signs clean with it present.
	     If a future signing error ever says this entitlement "could not be included in
	     profile," re-add it the same way (+ Capability), not by hand-editing this key. -->
	<key>com.apple.developer.proximity-reader.payment.acceptance</key>
	<true/>
</dict>
</plist>
